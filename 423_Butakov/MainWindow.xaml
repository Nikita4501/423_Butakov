<Window x:Class="_423_Butakov.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Практическая работа 4 Бутаков" Height="650" Width="900"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Страница 1" Click="ButtonPage1_Click" Margin="5" Padding="15,5" ToolTip="Перейти к первой функции"/>
            <Button Content="Страница 2" Click="ButtonPage2_Click" Margin="5" Padding="15,5" ToolTip="Перейти ко второй функции"/>
            <Button Content="Страница 3" Click="ButtonPage3_Click" Margin="5" Padding="15,5" ToolTip="Перейти к табуляции и графику"/>
        </StackPanel>

        <Frame x:Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>